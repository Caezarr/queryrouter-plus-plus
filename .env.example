# QueryRouter++ environment variables
# Copy to .env and fill in values

# Data directory (default: ./data_models)
QUERYROUTER_DATA_DIR=./data_models

# API settings
QUERYROUTER_HOST=0.0.0.0
QUERYROUTER_PORT=8000
QUERYROUTER_DEFAULT_STRATEGY=direct  # direct | cascade | embedding
QUERYROUTER_CASCADE_THRESHOLD=0.6

# Provider API keys (for /v1/chat/completions proxy)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
DASHSCOPE_API_KEY=

# Optional: override provider base URLs
# QUERYROUTER_OPENAI_BASE_URL=https://api.openai.com/v1
# QUERYROUTER_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Optional: telemetry (disabled by default)
QUERYROUTER_TELEMETRY=false
